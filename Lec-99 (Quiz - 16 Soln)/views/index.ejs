<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Bootstrap Demo</title>

  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css"
    rel="stylesheet"
    crossorigin="anonymous"
  />
</head>

<body>

  <!-- Navigation -->
  <header>
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
      <div class="container-fluid">
        <a class="navbar-brand" href="#">Navbar</a>

        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item"><a class="nav-link active" href="#">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#">Link</a></li>
          </ul>

          <form class="d-flex" role="search">
            <input class="form-control me-2" type="search" placeholder="Search" />
            <button class="btn btn-outline-success" type="submit">Search</button>
          </form>
        </div>
      </div>
    </nav>
  </header>

  <!-- Carousel -->
  <main class="mt-3">
    <section id="carouselExample" class="carousel slide container">
      <div class="carousel-inner rounded shadow-sm">

        <div class="carousel-item active">
          <img
            src="https://wallpapers.com/images/featured/beautiful-scenery-wnxju2647uqrcccv.jpg"
            class="d-block w-100"
            style="height: 400px; object-fit: cover"
            alt="Scenery"
          />
        </div>

        <div class="carousel-item">
          <img
            src="https://wallpapers.com/images/featured/beautiful-scenery-wnxju2647uqrcccv.jpg"
            class="d-block w-100"
            style="height: 400px; object-fit: cover"
            alt="Scenery"
          />
        </div>

      </div>

      <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
      </button>

      <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
      </button>
    </section>

    <!-- Action Section -->
    <section class="container text-center mt-4">
      <button id="generateBtn" class="btn btn-success">
        Generate Now
      </button>
    </section>
  </main>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    /**
     * Generate button click handler
     * Sends a GET request to `/generate` endpoint and logs
     * the JSON response.
     */
    document.getElementById("generateBtn").addEventListener("click", async () => {
      try {
        console.log("Generate button clicked");

        const response = await fetch("/generate");
        const result = await response.json();

        console.log("Server response:", result);
      } catch (error) {
        console.error("Request failed:", error);
      }
    });
  </script>

</body>
</html>
